# Anthropic API key from the account where the DripShopLive MCP is connected.
# This is NOT the Claude Code login account.
ANTHROPIC_API_KEY=

# Metricool REST API credentials. Both come from Metricool dashboard →
# Settings → API. Names match Metricool's own conventions.
METRICOOL_USER_TOKEN=
METRICOOL_USER_ID=

# Optional: explicit blog ID override for find_instagram_brand(). When set,
# takes precedence over the "drip tcg" name match. Use this if the auto-match
# picks the wrong brand or finds zero / multiple matches.
METRICOOL_BLOG_ID=

# Slack notification target. Bot token (xoxb-...) from a custom Slack app
# with chat:write scope, installed to the workspace. Channel ID (Cxxxxx,
# not channel name) — get from Slack → channel → "Copy channel ID".
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# Image hosting — GitHub Contents API upload. In GitHub Actions, the
# GITHUB_TOKEN env var is provided automatically with contents:write
# scope on the workflow's own repo. For local-dev testing, set a PAT
# here with the same scope, or skip the upload step and write to a
# local file.
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=
